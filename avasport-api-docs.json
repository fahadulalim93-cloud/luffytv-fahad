    "html": "<html lang=\"en\"><head>\n<meta charset=\"UTF-8\">\n<title>ABCSPORT API</title>\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n\n<style>\nbody{\n    background:#080808;\n    color:white;\n    font-family:Arial, sans-serif;\n    margin:0;\n    padding:40px;\n}\n\nh1{\n    color:#00ffcc;\n    font-size:42px;\n    margin-bottom:30px;\n}\n\n.card{\n    background:#111;\n    padding:28px;\n    border-radius:12px;\n    margin-bottom:26px;\n}\n\n.card h2{\n    margin-top:0;\n    font-size:30px;\n}\n\n.card p{\n    font-size:20px;\n}\n\ncode{\n    display:inline-block;\n    background:#1c1c1c;\n    color:white;\n    padding:8px 10px;\n    border-radius:7px;\n    font-size:16px;\n    word-break:break-all;\n}\n\na{\n    display:inline-block;\n    margin-top:18px;\n    color:#00ffcc;\n    font-size:22px;\n    text-decoration:none;\n}\n\na:hover{\n    text-decoration:underline;\n}\n\n@media(max-width:768px){\n    body{\n        padding:20px;\n    }\n\n    h1{\n        font-size:34px;\n    }\n\n    .card h2{\n        font-size:25px;\n    }\n\n    .card p{\n        font-size:18px;\n    }\n}\n</style>\n</head>\n\n<body>\n\n<h1>ABCSPORT API</h1>\n\n<div class=\"card\">\n    <h2>🗓️ Events API</h2>\n    <p>Live sports events (auto update)</p>\n    <code>https://avasport.top/api.php</code>\n    <br>\n    <a href=\"https://avasport.top/api.php\" target=\"_blank\">Open API</a>\n</div>\n\n<div class=\"card\">\n    <h2>📺 Channels API</h2>\n    <p>All TV channels list</p>\n    <code>https://avasport.top/channels_api.php</code>\n    <br>\n    <a href=\"https://avasport.top/channels_api.php\" target=\"_blank\">Open API</a>\n</div>\n\n<div class=\"card\">\n    <h2>🌍 Combined API (optional)</h2>\n    <p>Events and channels in one JSON response</p>\n    <code>https://avasport.top/api_all.php</code>\n    <br>\n    <a href=\"https://avasport.top/api_all.php\" target=\"_blank\">Open API</a>\n</div>\n\n\n</body></html>",
